{% extends "common/layout.njk" %}

{% block title %}
  <title>Run Evaluation | {{ serviceName }}</title>
{% endblock %}

{% block content %}
  <h1 class="govuk-heading-xl">Run Evaluation</h1>

  {% if error %}
    <div class="govuk-error-summary" data-module="govuk-error-summary">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <p class="govuk-body">{{ error }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <form method="post" action="/evaluation/run">
    <div class="govuk-form-group {% if error %}govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--m" for="body">
        Request body (JSON)
      </label>
      <div id="body-hint" class="govuk-hint">
        Provide the evaluation request as JSON. Include group_id, snapshot_id, queries, rubrics and models.
      </div>
      {% if error %}
        <p id="body-error" class="govuk-error-message">
          <span class="govuk-visually-hidden">Error:</span> {{ error }}
        </p>
      {% endif %}
      <textarea
        class="govuk-textarea govuk-!-font-family-monospace"
        id="body"
        name="body"
        rows="20"
        aria-describedby="body-hint{% if error %} body-error{% endif %}"
      >{{ defaultBody }}</textarea>
    </div>

    <button class="govuk-button" data-module="govuk-button">
      Submit evaluation
    </button>
  </form>
{% endblock %}