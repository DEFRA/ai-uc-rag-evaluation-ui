{% extends "common/layout.njk" %}

{% block title %}
  <title>Upload source file | {{ serviceName }}</title>
{% endblock %}

{% block content %}
  <h1 class="govuk-heading-xl">Upload source file</h1>

  {% if error %}
    <div class="govuk-error-summary" data-module="govuk-error-summary">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#file">{{ error }}</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <form method="post" action="{{ uploadUrl }}" enctype="multipart/form-data">
    <div class="govuk-form-group{% if error %} govuk-form-group--error{% endif %}">
      <label class="govuk-label" for="file">Upload a file</label>
      {% if error %}
        <p class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ error }}</p>
      {% endif %}
      <input class="govuk-file-upload{% if error %} govuk-file-upload--error{% endif %}" id="file" name="file" type="file">
    </div>

    <button type="submit" class="govuk-button">Upload file</button>
  </form>
{% endblock %}
